{
  "name": "aurora-sans",
  "label": "Aurora Sans",
  "extends": "dark-aurora-noir",
  "mermaidTheme": "dark",
  "mermaidTransparentBackground": true,
  "tokens": {
    "--md-preview-body-font": "\"Inter\", -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif",
    "--md-preview-line-height": "1.7",

    "--md-preview-body-color": "#e8e6ec",
    "--md-preview-link-color": "#dcaf32",
    "--md-preview-content-bg": "radial-gradient(ellipse 80% 60% at 0% 0%, rgba(75, 45, 26, 0.30), transparent 58%), radial-gradient(ellipse 70% 58% at 100% 8%, rgba(10, 28, 42, 0.70), transparent 62%), linear-gradient(115deg, rgba(24, 20, 17, 0.98) 0%, rgba(10, 13, 16, 0.98) 44%, rgba(3, 7, 13, 0.98) 100%)",
    "--md-preview-content-border": "rgba(220, 175, 50, 0.10)",
    "--md-preview-table-header-bg": "linear-gradient(135deg, #c49a1a, #dcaf32)",
    "--md-preview-code-bg": "#0d121a",

    "--md-preview-heading-color": "#ffffff",
    "--md-preview-heading-surface-color-h1": "#1b1926",
    "--md-preview-heading-surface-color-h2": "#1b1926",
    "--md-preview-heading-divider-color-h1": "transparent",
    "--md-preview-heading-divider-color-h2": "transparent",
    "--md-preview-heading-radius-h1": "14px",
    "--md-preview-heading-radius-h2": "12px",
    "--md-preview-heading-padding-block-h1": "0.5em",
    "--md-preview-heading-padding-block-h2": "0.38em",
    "--md-preview-heading-padding-inline-h1": "38px",
    "--md-preview-heading-padding-inline-h2": "30px",
    "--md-preview-heading-shadow-h1": "0 10px 24px rgba(220, 175, 50, 0.28)",
    "--md-preview-heading-shadow-h2": "0 8px 20px rgba(220, 175, 50, 0.20)",
    "--md-preview-heading-offset-inline-h1": "38px",
    "--md-preview-heading-offset-inline-h2": "22px",
    "--md-preview-heading-bg-h1": "linear-gradient(135deg, #c49a1a, #dcaf32)",
    "--md-preview-heading-bg-h2": "linear-gradient(135deg, #a07e10, #c49a1a)"
  }
}
