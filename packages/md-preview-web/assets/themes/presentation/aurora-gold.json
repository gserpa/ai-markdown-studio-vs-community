{
  "name": "aurora-gold",
  "label": "Aurora Gold",
  "extends": "galaxy",
  "mermaidTheme": "dark",
  "mermaidTransparentBackground": true,
  "tokens": {
    "--presentation-accent": "#dcaf32",
    "--presentation-accent-soft": "#f0d070",
    "--presentation-body-color": "#e8e4d8",
    "--presentation-link-color": "#dcaf32",
    "--presentation-title-color": "#f8f4e0",

    "--presentation-surface-bg": "radial-gradient(ellipse 80% 60% at 0% 0%, rgba(75, 45, 10, 0.28), transparent 55%), linear-gradient(175deg, #1c1810, #10110c)",
    "--presentation-surface-border": "rgba(220, 175, 50, 0.16)",
    "--presentation-surface-shadow": "0 28px 80px rgba(0, 0, 0, 0.55)",
    "--presentation-standard-header-bg": "linear-gradient(180deg, #c49a1a, #a07e10)",
    "--presentation-standard-content-bg": "#131008",
    "--presentation-panel-bg": "#1a160c",
    "--presentation-panel-bg-soft": "#120f07",
    "--presentation-panel-border": "rgba(220, 175, 50, 0.14)",
    "--presentation-pill-bg": "rgba(220, 175, 50, 0.10)",
    "--presentation-pill-border": "rgba(220, 175, 50, 0.22)",
    "--presentation-pill-color": "#dcaf32",

    "--presentation-media-bg": "linear-gradient(160deg, #2a2010, #181408)",
    "--presentation-cover-caption-bg": "rgba(255, 255, 255, 0.06)",
    "--presentation-cover-caption-border": "rgba(220, 175, 50, 0.18)",
    "--presentation-divider-overlay-bg": "linear-gradient(90deg, rgba(10, 8, 3, 0.24), rgba(10, 8, 3, 0.70))",

    "--presentation-inline-code-bg": "rgba(220, 175, 50, 0.10)",
    "--presentation-inline-code-border": "rgba(220, 175, 50, 0.18)",
    "--presentation-inline-code-color": "#dcaf32",
    "--presentation-code-bg": "rgba(220, 175, 50, 0.07)",
    "--presentation-code-border": "rgba(220, 175, 50, 0.14)",
    "--presentation-code-hover-accent": "#f0c847",
    "--presentation-code-hover-bg": "rgba(220, 175, 50, 0.14)",
    "--presentation-code-hover-border": "rgba(220, 175, 50, 0.26)",
    "--presentation-code-keyword-color": "#f0883e",
    "--presentation-code-number-color": "#dcaf32",
    "--presentation-code-string-color": "#87c78f",
    "--presentation-code-title-color": "#dcaf32",
    "--presentation-code-type-color": "#80cbc4",
    "--presentation-code-meta-color": "#50a0c8",

    "--presentation-hover-accent": "#f0c847",
    "--presentation-hover-bg": "rgba(220, 175, 50, 0.14)",
    "--presentation-hover-bg-soft": "rgba(220, 175, 50, 0.08)",
    "--presentation-hover-border": "rgba(220, 175, 50, 0.24)",

    "--presentation-table-border": "rgba(220, 175, 50, 0.18)",
    "--presentation-table-header-bg": "linear-gradient(180deg, #c49a1a, #a07e10)",
    "--presentation-table-header-color": "#05080d",
    "--presentation-table-cell-bg": "rgba(220, 175, 50, 0.03)",
    "--presentation-table-row-alt-bg": "rgba(220, 175, 50, 0.06)",

    "--presentation-blockquote-bg": "rgba(220, 175, 50, 0.06)",
    "--presentation-blockquote-border": "rgba(220, 175, 50, 0.28)"
  }
}
