{
  "name": "autumn-ember",
  "label": "Autumn Ember",
  "mermaidTheme": "dark",
  "mermaidTransparentBackground": true,
  "tokens": {
    "--presentation-accent": "#e8722a",
    "--presentation-accent-soft": "#f8b880",
    "--presentation-contrast": "#ffffff",
    "--presentation-body-color": "#f0e8dc",
    "--presentation-muted-color": "#c4a48a",
    "--presentation-emphasis-color": "#f8ede0",
    "--presentation-link-color": "#f08040",
    "--presentation-title-color": "#f8f0e8",

    "--presentation-surface-bg": "linear-gradient(175deg, #1e0e04, #130802)",
    "--presentation-surface-border": "rgba(232, 114, 42, 0.18)",
    "--presentation-surface-shadow": "0 28px 80px rgba(0, 0, 0, 0.55)",
    "--presentation-standard-header-bg": "linear-gradient(180deg, #c85c18, #b84e0c)",
    "--presentation-standard-content-bg": "#150903",
    "--presentation-panel-bg": "#1a0d04",
    "--presentation-panel-bg-soft": "#120802",
    "--presentation-panel-border": "rgba(232, 114, 42, 0.14)",
    "--presentation-pill-bg": "rgba(232, 114, 42, 0.10)",
    "--presentation-pill-border": "rgba(232, 114, 42, 0.22)",
    "--presentation-pill-color": "#f0c898",
    "--presentation-body-bg": "rgba(255, 255, 255, 0.04)",
    "--presentation-body-border": "rgba(232, 114, 42, 0.10)",

    "--presentation-media-bg": "linear-gradient(160deg, #3a1c08, #1e0c04)",
    "--presentation-media-frame-bg": "rgba(255, 255, 255, 0.04)",
    "--presentation-cover-caption-bg": "rgba(255, 255, 255, 0.06)",
    "--presentation-cover-caption-border": "rgba(255, 255, 255, 0.14)",
    "--presentation-divider-overlay-bg": "linear-gradient(90deg, rgba(13, 7, 3, 0.24), rgba(13, 7, 3, 0.70))",

    "--presentation-inline-code-bg": "rgba(232, 114, 42, 0.12)",
    "--presentation-inline-code-border": "rgba(232, 114, 42, 0.18)",
    "--presentation-inline-code-color": "#f0c898",
    "--presentation-code-bg": "rgba(232, 114, 42, 0.08)",
    "--presentation-code-border": "rgba(232, 114, 42, 0.14)",
    "--presentation-code-text-color": "#f0e8dc",
    "--presentation-code-hover-accent": "#f08040",
    "--presentation-code-hover-bg": "rgba(232, 114, 42, 0.14)",
    "--presentation-code-hover-border": "rgba(232, 114, 42, 0.26)",
    "--presentation-code-comment-color": "#9a836a",
    "--presentation-code-keyword-color": "#e87040",
    "--presentation-code-number-color": "#e8c030",
    "--presentation-code-string-color": "#94c878",
    "--presentation-code-title-color": "#e8a038",
    "--presentation-code-type-color": "#74c8c4",
    "--presentation-code-meta-color": "#48b0d0",

    "--presentation-hover-accent": "#f08040",
    "--presentation-hover-bg": "rgba(232, 114, 42, 0.14)",
    "--presentation-hover-bg-soft": "rgba(232, 114, 42, 0.08)",
    "--presentation-hover-border": "rgba(232, 114, 42, 0.24)",

    "--presentation-table-bg": "rgba(255, 255, 255, 0.025)",
    "--presentation-table-border": "rgba(232, 114, 42, 0.18)",
    "--presentation-table-header-bg": "linear-gradient(180deg, #c85c18, #b84e0c)",
    "--presentation-table-header-color": "#f8f0e8",
    "--presentation-table-cell-bg": "rgba(232, 114, 42, 0.03)",
    "--presentation-table-cell-color": "#f0e8dc",
    "--presentation-table-row-alt-bg": "rgba(232, 114, 42, 0.06)",

    "--presentation-blockquote-bg": "rgba(232, 114, 42, 0.06)",
    "--presentation-blockquote-border": "rgba(232, 114, 42, 0.30)"
  }
}
