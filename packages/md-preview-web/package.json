    "@fontsource/jetbrains-mono": "^5.2.8",
    "@mfo/core": "*",
    "dompurify": "^3.4.1",
    "jsdom": "^26.0.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}
