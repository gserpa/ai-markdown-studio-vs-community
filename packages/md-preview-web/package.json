{
  "name": "@mfo/preview-web",
  "version": "0.0.1",
  "license": "MIT",
  "description": "Shared browser-based Markdown and presentation preview for AI Markdown Studio.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsc -p ./tsconfig.json",
    "build:browser": "node build-browser.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.2.8",
