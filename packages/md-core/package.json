{
  "name": "@mfo/core",
  "version": "0.0.1",
  "license": "MIT",
  "description": "Shared Markdown rendering, MPS parsing, and presentation logic for AI Markdown Studio.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p ./tsconfig.json",
    "build:browser": "node build-browser.mjs",
